{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "minor": {
    "automerge": true
  },
  "patch": {
    "automerge": true
  },
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "commitMessagePrefix": "ci:",
      "automerge": true
    }
  ]
}
